{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/jaza-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=jaza_venus;Username=jaza_app;Password=ChangeMe!Dev2026"
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:5173", "http://localhost:5173" ]
  },
  "Cookie": {
    "Name": "jaza.auth",
    "Domain": null,
    "SecurePolicy": "Always",
    "ExpirationHours": 24
  },
  "Jwt": {
    "Issuer": "jaza-venus",
    "Audience": "jaza-venus-app",
    "AccessTokenMinutes": 15,
    "RefreshTokenHours": 24,
    "SigningKey": null
  },
  "Auth": {
    "RequireSuperAdminMfa": true
  },
  "RateLimit": {
    "GlobalPermitsPerMinute": 240,
    "LoginPermitsPerMinute": 10,
    "RefreshPermitsPerMinute": 30
  },
  "Seed": {
    "SuperAdminEmail": "superadmin@jaza.local",
    "SuperAdminPassword": null,
    "DeveloperEmail": null,
    "DeveloperPassword": null,
    "IncludeDemoUsers": false
  },
  "AllowedHosts": "*"
}
