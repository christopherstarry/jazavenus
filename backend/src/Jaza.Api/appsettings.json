{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/jaza-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=JazaVenus;User Id=sa;Password=ChangeMe!Dev2026;TrustServerCertificate=True;Encrypt=True;MultipleActiveResultSets=true"
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:5173", "http://localhost:5173" ]
  },
  "Cookie": {
    "Name": "jaza.auth",
    "Domain": null,
    "SecurePolicy": "Always",
    "SlidingExpirationMinutes": 60,
    "AbsoluteExpirationHours": 12
  },
  "RateLimit": {
    "GlobalPermitsPerMinute": 240,
    "LoginPermitsPerMinute": 5
  },
  "Seed": {
    "SuperAdminEmail": "superadmin@jaza.local",
    "SuperAdminPassword": null
  },
  "AllowedHosts": "*"
}
