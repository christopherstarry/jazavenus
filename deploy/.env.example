# Production environment for docker-compose. Copy to .env and fill in.
# chmod 600 .env  (root-owned)

DOMAIN=warehouse.example.com
ACME_EMAIL=ops@example.com
IMAGE_TAG=latest

# Strong, randomly generated passwords. NEVER reuse across environments.
SQL_SA_PASSWORD=Replace-With-32-Char-Random-Password!
SEED_SUPERADMIN_EMAIL=owner@example.com
# Leave blank to have the API generate one and print it to the log on first boot.
SEED_SUPERADMIN_PASSWORD=
