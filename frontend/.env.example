# Local dev: leave unset or use /api — Vite proxies /api → https://localhost:5001 (see vite.config.ts).
# VITE_API_BASE_URL=/api

# GitHub Pages / any static host on another origin: bake the public API root at build time (must include /api).
# VITE_API_BASE_URL=https://jaza-venus.fly.dev/api

# Static deploys: skip cookie antiforgery bootstrap; login still works via JWT Bearer from /api/auth/login.
# VITE_SKIP_ANTIFORGERY=true
