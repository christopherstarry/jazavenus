# Local dev: leave unset or use /api — Vite proxies /api → https://localhost:5001 (see vite.config.ts).
# VITE_API_BASE_URL=/api

# Vercel uses same-origin /api and rewrites it to Fly in vercel.json.
# You do not need VITE_API_BASE_URL on Vercel. Keep this only for non-Vercel static hosts.
# VITE_API_BASE_URL=https://jaza-venus.fly.dev/api
